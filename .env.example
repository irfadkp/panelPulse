# PanelPulse Configuration Template
# Copy this file to .env and customize as needed

# ============================================
# AI Provider Configuration
# ============================================
# Choose your AI provider: chatgpt, gemini, or mock
# - chatgpt: OpenAI's ChatGPT (requires OPENAI_API_KEY)
# - gemini: Google's Gemini (requires GEMINI_API_KEY)
# - mock: Simple rule-based responses (no API key needed)
AI_PROVIDER=gemini

# ============================================
# OpenAI ChatGPT Configuration
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# Optional: Specify model (gpt-4, gpt-3.5-turbo, gpt-4-turbo)
OPENAI_MODEL=gpt-4

# ============================================
# Google Gemini Configuration
# ============================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: Specify model (gemini-pro, gemini-pro-vision)
GEMINI_MODEL=gemini-pro

# ============================================
# Application Settings
# ============================================
# Add any custom configuration here if needed in the future
